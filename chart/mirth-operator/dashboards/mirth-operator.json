    {
      "type": "state-timeline",
      "title": "Channel State Timeline",
      "description": "State over time per channel. Encoded 1=STARTED, 2=PAUSED, 3=STOPPED, 4=ERROR, 5=UNKNOWN \u2014 value-mapped to names + colors.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "id": 20,
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "fillOpacity": 90,
            "lineWidth": 0
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "color": "green",
                  "index": 0,
                  "text": "STARTED"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "color": "yellow",
                  "index": 1,
                  "text": "PAUSED"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "3": {
                  "color": "red",
                  "index": 2,
                  "text": "STOPPED"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "4": {
                  "color": "red",
                  "index": 3,
                  "text": "ERROR"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "5": {
                  "color": "purple",
                  "index": 4,
                  "text": "UNKNOWN"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "transparent",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "alignValue": "left",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "auto",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "sum without(state) (mirth_channel_status{instance=~\"$instance\",channel=~\"$channel\",state=\"STARTED\"} * 1 == 1) or sum without(state) (mirth_channel_status{instance=~\"$instance\",channel=~\"$channel\",state=\"PAUSED\"} * 2 == 2) or sum without(state) (mirth_channel_status{instance=~\"$instance\",channel=~\"$channel\",state=\"STOPPED\"} * 3 == 3) or sum without(state) (mirth_channel_status{instance=~\"$instance\",channel=~\"$channel\",state=\"ERROR\"} * 4 == 4) or sum without(state) (mirth_channel_status{instance=~\"$instance\",channel=~\"$channel\",state=\"UNKNOWN\"} * 5 == 5)",
          "legendFormat": "{{channel}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
