{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Mirth Operator — reconciliation health, channel state, throughput, queue depth, remediation, and deploy errors across managed MirthInstance CRs.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["mirth", "operator", "integrations"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(mirth_up, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": true,
        "name": "instance",
        "options": [],
        "query": { "query": "label_values(mirth_up, instance)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(mirth_channel_status{instance=~\"$instance\"}, channel)",
        "hide": 0,
        "includeAll": true,
        "label": "Channel",
        "multi": true,
        "name": "channel",
        "options": [],
        "query": { "query": "label_values(mirth_channel_status{instance=~\"$instance\"}, channel)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Mirth Operator",
  "uid": "mirth-operator",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Instances Up",
      "description": "Count of MirthInstance CRs whose REST API is currently reachable.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        { "expr": "sum(mirth_up{instance=~\"$instance\"})", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "stat",
      "title": "Total Channels",
      "description": "Sum of deployed channels across selected Mirth instances.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "sum(mirth_channels_total{instance=~\"$instance\"})", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "stat",
      "title": "Healthy Channels",
      "description": "Channels currently in STARTED state.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "sum(mirth_channels_healthy{instance=~\"$instance\"})", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "stat",
      "title": "Unhealthy Channels",
      "description": "Channels not in STARTED state (total - healthy).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "clamp_min(sum(mirth_channels_total{instance=~\"$instance\"}) - sum(mirth_channels_healthy{instance=~\"$instance\"}), 0)", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "stat",
      "title": "Queue Depth",
      "description": "Sum of pending messages queued across all selected channels.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "sum(mirth_channel_messages_queued{instance=~\"$instance\",channel=~\"$channel\"})", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "stat",
      "title": "JVM Heap Used",
      "description": "Aggregate JVM heap in use across selected instances.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlPu" },
          "unit": "bytes"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "sum(mirth_jvm_heap_used_bytes{instance=~\"$instance\"})", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "row",
      "title": "Channel Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Messages Received / 5m",
      "description": "Delta of messages received per channel over 5m windows.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 10,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "mode": "none", "group": "A" }
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "clamp_min(delta(mirth_channel_messages_received_total{instance=~\"$instance\",channel=~\"$channel\"}[5m]), 0)", "legendFormat": "{{channel}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Messages Sent / 5m",
      "description": "Delta of messages sent per channel over 5m windows.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "clamp_min(delta(mirth_channel_messages_sent_total{instance=~\"$instance\",channel=~\"$channel\"}[5m]), 0)", "legendFormat": "{{channel}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Errored Messages / 5m",
      "description": "Delta of errored messages per channel over 5m windows. Spikes mean trouble.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 12,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-RdYlGr" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "hue",
            "lineWidth": 0,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "clamp_min(delta(mirth_channel_messages_errored_total{instance=~\"$instance\",channel=~\"$channel\"}[5m]), 0)", "legendFormat": "{{channel}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue Depth by Channel",
      "description": "Current pending messages per channel. Sustained growth indicates a stuck downstream.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 13,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "mirth_channel_messages_queued{instance=~\"$instance\",channel=~\"$channel\"}", "legendFormat": "{{channel}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "row",
      "title": "Channel Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 102,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "state-timeline",
      "title": "Channel State Timeline",
      "description": "State over time for each channel — green STARTED, yellow PAUSED, red STOPPED/UNKNOWN.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "id": 20,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "fillOpacity": 80, "lineWidth": 0 },
          "mappings": [
            { "type": "value", "options": { "STARTED": { "color": "green", "index": 0 }, "PAUSED": { "color": "yellow", "index": 1 }, "STOPPED": { "color": "red", "index": 2 }, "UNKNOWN": { "color": "purple", "index": 3 } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }] }
        }
      },
      "options": {
        "alignValue": "left",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "auto",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        { "expr": "label_replace(label_replace(mirth_channel_status{instance=~\"$instance\",channel=~\"$channel\"} == 1, \"series\", \"$1\", \"channel\", \"(.+)\"), \"\", \"\", \"\", \"\")", "legendFormat": "{{channel}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "transformations": [
        { "id": "renameByRegex", "options": { "regex": ".*channel=\"([^\"]+)\".*state=\"([^\"]+)\".*", "renamePattern": "$1" } }
      ]
    },
    {
      "type": "bargauge",
      "title": "Top 10 Channels by Errors (range)",
      "description": "Channels with the most errored messages in the selected time range.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "id": 21,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-RdYlGr" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 100 }] },
          "unit": "short"
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        { "expr": "topk(10, clamp_min(sum by (channel) (delta(mirth_channel_messages_errored_total{instance=~\"$instance\",channel=~\"$channel\"}[$__range])), 0))", "legendFormat": "{{channel}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "bargauge",
      "title": "Top 10 Channels by Queue Depth",
      "description": "Deepest queues right now.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "id": 22,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-YlBl" },
          "unit": "short"
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        { "expr": "topk(10, sum by (channel) (mirth_channel_messages_queued{instance=~\"$instance\",channel=~\"$channel\"}))", "legendFormat": "{{channel}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "row",
      "title": "Operator Actions & Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 103,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Remediation Attempts / 5m",
      "description": "Rate of operator remediation attempts, bucketed by result (success/failure/etc).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "id": 30,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 0,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "sum by (result) (rate(mirth_remediation_total{instance=~\"$instance\",channel=~\"$channel\"}[5m]) * 300)", "legendFormat": "{{result}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Deploy Errors / 5m",
      "description": "Compile, deploy, or script error events surfaced from Mirth's /api/events endpoint.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "id": 31,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 0,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "sum by (event_name) (rate(mirth_deploy_errors_total{instance=~\"$instance\",channel=~\"$channel\"}[5m]) * 300)", "legendFormat": "{{event_name}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    },
    {
      "type": "table",
      "title": "Recent Deploy Errors (top by count)",
      "description": "Deploy-error counters aggregated over the dashboard time range, grouped by channel and event.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "id": 32,
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }, { "id": "color", "value": { "mode": "continuous-RdYlGr" } }] }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Value" }]
      },
      "targets": [
        { "expr": "topk(20, sum by (instance, channel, event_name) (increase(mirth_deploy_errors_total{instance=~\"$instance\",channel=~\"$channel\"}[$__range])))", "format": "table", "instant": true, "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true }, "renameByName": { "instance": "Instance", "channel": "Channel", "event_name": "Event", "Value": "Count" } } }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Used",
      "description": "Heap memory in use per Mirth instance.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "id": 33,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "bytes"
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "mirth_jvm_heap_used_bytes{instance=~\"$instance\"}", "legendFormat": "{{instance}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ]
    }
  ]
}
