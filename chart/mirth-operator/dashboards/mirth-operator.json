    {
      "type": "stat",
      "title": "Success Rate",
      "description": "Percent of messages delivered successfully over the selected range: sent / (sent + errored). Green \u2265 99%, yellow \u2265 95%, red below.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 7
      },
      "id": 106,
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "(sum(clamp_min(delta(mirth_channel_messages_sent_total{instance=~\"$instance\",channel=~\"$channel\"}[$__range]), 0)) / clamp_min(sum(clamp_min(delta(mirth_channel_messages_sent_total{instance=~\"$instance\",channel=~\"$channel\"}[$__range]), 0)) + sum(clamp_min(delta(mirth_channel_messages_errored_total{instance=~\"$instance\",channel=~\"$channel\"}[$__range]), 0)), 1)) * 100",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Messages Received / 5m",
